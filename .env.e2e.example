# Optional override for app url used by Playwright
E2E_BASE_URL=http://127.0.0.1:5173

# Required for full-cycle test (existing real user in your Supabase project)
E2E_USER_EMAIL=your-test-user@example.com
E2E_USER_PASSWORD=your-test-password

# Optional: bypass external edge function check-slug instability in CI/local
# E2E_MOCK_CHECK_SLUG=1
